{
  "name": "Windows Norwegian (nb-NO)",
  "firmware_model": "ZMK sends US HID scancodes. Windows Norwegian layout maps them to NO glyphs. Only ø/æ/å use coach labels on base; all other keys keep US/international scancodes.",
  "coach_match_order": ["event.code", "norwegian_event.key", "visual_label", "us_event.key"],
  "programming_on_norwegian_windows": {
    "summary": "HID scancodes are layout-independent; Windows Norwegian maps several US programming keys to Norwegian letters and different punctuation.",
    "scancode_to_norwegian_glyph": {
      "1 and Bang": "1 / !",
      "2 and At": "2 / \" (AltGr @)",
      "3 and Hash": "3 / # (AltGr £)",
      "4 and Dollar": "4 / ¤ (AltGr $)",
      "5 and Percent": "5 / % (AltGr €)",
      "6 and Caret": "6 / &",
      "7 and Ampersand": "7 / / (AltGr {)",
      "8 and Star": "8 / ( (AltGr [)",
      "9 and Left Bracket": "9 / ) (AltGr ])",
      "0 and Right Bracket": "0 / = (AltGr })",
      "SemiColon and Colon": "ø (not ;)",
      "Left Apos and Double": "æ (not ')",
      "Left Brace": "å (not [)",
      "Left Bracket": "å (same [ scancode as Left Brace)",
      "Right Bracket": "¨ / ^ dead keys (not ])",
      "ForwardSlash and QuestionMark": "- / _ (not /)",
      "Backslash and Pipe": "' / * (not \\)",
      "Equal and Plus": "\\ / ` dead key (not =)",
      "Minus": "+ / ?"
    },
    "english_punctuation_options": [
      "Win+Space or F16 (L4) to switch Windows to US English while coding",
      "Layer 1 bracket keys still highlight correctly in the coach via event.code; output follows Norwegian mapping unless layout is English"
    ]
  },
  "norwegian_base_exceptions": [
    { "x": 11, "y": 2, "label": "ø", "zmk_parameter": "SemiColon and Colon", "event_code": "Semicolon" },
    { "x": 12, "y": 2, "label": "æ", "zmk_parameter": "Left Apos and Double", "event_code": "Quote" },
    { "x": 12, "y": 1, "label": "å", "zmk_parameter": "Left Brace", "event_code": "BracketLeft" }
  ],
  "zmk_parameter_aliases": {
    "SemiColon": ["SemiColon", "SemiColon and Colon"],
    "Left Apos and Double": ["Left Apos and Double", "Apostrophe", "Keyboard Apostrophe"],
    "Left Brace": ["Left Brace", "Left Bracket"],
    "Right Bracket": ["Right Bracket", "Right Brace"],
    "Backslash and Pipe": ["Backslash and Pipe", "Backslash"],
    "Comma and LessThan": ["Comma and LessThan", "Comma"],
    "ForwardSlash and QuestionMark": ["ForwardSlash and QuestionMark", "ForwardSlash"],
    "Period": ["Period", "Period and GreaterThan"],
    "Spacebar": ["Spacebar", "Space"],
    "Return": ["Return", "Return Enter", "Enter"],
    "Grave": ["Grave", "Grave Accent and Tilde"],
    "Equal": ["Equal", "Equal and Plus"],
    "1": ["1", "1 and Bang"],
    "2": ["2", "2 and At"],
    "3": ["3", "3 and Hash"],
    "4": ["4", "4 and Dollar"],
    "5": ["5", "5 and Percent"],
    "6": ["6", "6 and Caret"],
    "7": ["7", "7 and Ampersand"],
    "8": ["8", "8 and Star"],
    "9": ["9", "9 and Left Bracket"],
    "0": ["0", "0 and Right Bracket"]
  },
  "zmk_to_host_output": {
    "1": { "normal": "1", "shift": "!", "us": "1" },
    "1 and Bang": { "normal": "1", "shift": "!", "us": "1" },
    "2": { "normal": "2", "shift": "\"", "altgr": "@", "us": "2" },
    "2 and At": { "normal": "2", "shift": "\"", "altgr": "@", "us": "2" },
    "3": { "normal": "3", "shift": "#", "altgr": "£", "us": "3" },
    "3 and Hash": { "normal": "3", "shift": "#", "altgr": "£", "us": "3" },
    "4": { "normal": "4", "shift": "¤", "altgr": "$", "us": "4" },
    "4 and Dollar": { "normal": "4", "shift": "¤", "altgr": "$", "us": "4" },
    "5": { "normal": "5", "shift": "%", "altgr": "€", "us": "5" },
    "5 and Percent": { "normal": "5", "shift": "%", "altgr": "€", "us": "5" },
    "6": { "normal": "6", "shift": "&", "us": "6" },
    "6 and Caret": { "normal": "6", "shift": "&", "us": "6" },
    "7": { "normal": "7", "shift": "/", "altgr": "{", "us": "7" },
    "7 and Ampersand": { "normal": "7", "shift": "/", "altgr": "{", "us": "7" },
    "8": { "normal": "8", "shift": "(", "altgr": "[", "us": "8" },
    "8 and Star": { "normal": "8", "shift": "(", "altgr": "[", "us": "8" },
    "9": { "normal": "9", "shift": ")", "altgr": "]", "us": "9" },
    "9 and Left Bracket": { "normal": "9", "shift": ")", "altgr": "]", "us": "9" },
    "0": { "normal": "0", "shift": "=", "altgr": "}", "us": "0" },
    "0 and Right Bracket": { "normal": "0", "shift": "=", "altgr": "}", "us": "0" },
    "SemiColon": { "normal": "ø", "shift": "Ø", "us": ";" },
    "SemiColon and Colon": { "normal": "ø", "shift": "Ø", "us": ";" },
    "Left Apos and Double": { "normal": "æ", "shift": "Æ", "us": "'" },
    "Left Brace": { "normal": "å", "shift": "Å", "us": "[" },
    "Left Bracket": { "normal": "å", "shift": "Å", "us": "[" },
    "Right Bracket": { "normal": "¨", "shift": "^", "altgr": "~", "dead": true, "us": "]" },
    "Right Brace": { "normal": "¨", "shift": "^", "altgr": "~", "dead": true, "us": "]" },
    "Backslash and Pipe": { "normal": "'", "shift": "*", "us": "\\" },
    "Backslash": { "normal": "'", "shift": "*", "us": "\\" },
    "ForwardSlash and QuestionMark": { "normal": "-", "shift": "_", "us": "/" },
    "ForwardSlash": { "normal": "-", "shift": "_", "us": "/" },
    "Minus": { "normal": "+", "shift": "?", "us": "-" },
    "Equal": { "normal": "\\", "shift": "`", "altgr": "´", "dead": true, "us": "=" },
    "Equal and Plus": { "normal": "\\", "shift": "`", "altgr": "´", "dead": true, "us": "=" },
    "Comma": { "normal": ",", "shift": ";", "us": "," },
    "Comma and LessThan": { "normal": ",", "shift": ";", "us": "," },
    "Period": { "normal": ".", "shift": ":", "us": "." },
    "Period and GreaterThan": { "normal": ".", "shift": ":", "us": "." },
    "Grave": { "normal": "|", "shift": "§", "us": "`" },
    "Grave Accent and Tilde": { "normal": "|", "shift": "§", "us": "`" }
  },
